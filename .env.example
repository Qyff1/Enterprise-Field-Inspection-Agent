# ============================================================
# 企业外勤核验智能Agent 配置模板
# 复制此文件为 .env 并填入你的真实密钥
# ============================================================

# DashScope (阿里云) API - 必填
API_KEY=sk-your-dashscope-api-key-here
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen3.6-plus
MAX_TOKENS=1000
TEMPERATURE=0.7
TIMEOUT=60
MAX_RETRIES=3
RETRY_DELAY=2.0

# Bocha Web Search API - 可选
BOCHA_API_KEY=sk-your-bocha-api-key-here

# 高德地图 API - 可选
AMAP_API_KEY=your-amap-api-key-here

# Flask 运行模式 (production / development)
FLASK_DEBUG=false
